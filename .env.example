# PostgreSQL connection string (local, Neon, Supabase, or Vercel Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/miyyahi?schema=public"

# Session secret — generate with: openssl rand -base64 32
SESSION_SECRET="replace-with-a-secure-random-string-min-32-chars"

# App URL (used for metadata and PWA)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Web Push (VAPID) — generate with: npm run generate:vapid
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"

# Optional: create the first admin user when running npm run db:seed
# ADMIN_PHONE="0501234567"
# ADMIN_PASSWORD="your-secure-password"
# ADMIN_NAME="مدير النظام"

# Optional: platform super admin (login with company slug "platform")
# SUPER_ADMIN_PHONE="0509999999"
# SUPER_ADMIN_PASSWORD="your-secure-password"
# SUPER_ADMIN_NAME="مدير المنصة"
