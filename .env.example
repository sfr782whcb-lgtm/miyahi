# Local development (SQLite file)
DATABASE_URL="file:./dev.db"

# Session secret — generate with: openssl rand -base64 32
SESSION_SECRET="replace-with-a-secure-random-string-min-32-chars"

# App URL (used for metadata and PWA)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Production (Turso — recommended for Vercel, keeps SQLite schema) ---
# DATABASE_URL="libsql://your-database-name.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# --- Production (PostgreSQL — future migration) ---
# Change provider in prisma/schema.prisma to "postgresql", then:
# DATABASE_URL="postgresql://user:password@host:5432/miyyahi?schema=public"
